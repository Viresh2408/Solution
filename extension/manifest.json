{
  "manifest_version": 3,
  "name": "TrustNet AI — Human Vulnerability Shield",
  "version": "1.0.0",
  "description": "Real-time social engineering protection. Analyzes URLs, emails, and page content for phishing, BEC, and manipulation attacks using AI-powered behavioral analysis.",

  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "notifications",
    "identity"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "https://safebrowsing.googleapis.com/*",
    "https://www.virustotal.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.abuseipdb.com/*",
    "https://cloudflare-dns.com/*",
    "https://api.shodan.io/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*", "popup/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
